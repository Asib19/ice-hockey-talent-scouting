		<properties node_id="14" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 1, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x02 \x00\x00\x01\x8f\x00\x00\x08y\x00\x00\x04\xe1\x00\x00\x02!\x00\x00\x01\xad\x00\x00\x08x\x00\x00\x04\xe0\x00\x00\x00\x00\x00\x00\x00\x00\n\x00\x00\x00\x02!\x00\x00\x01\xad\x00\x00\x08x\x00\x00\x04\xe0', 'scriptLibrary': [{'name': 'suspicious data', 'script': 'from Orange.data import Domain, DiscreteVariable\n\nsus_var = DiscreteVariable("suspicious", values=["False", "True"])\n\nnew_domain = Domain(in_data.domain.attributes + (sus_var,), in_data.domain.class_vars)\n\nout_data = in_data.transform(new_domain) # add col\n\ncol_idx = in_data.domain.index("shooting_percentage_calculated")\nmask = (in_data.X[:, col_idx] &gt; 65)[:, None] # because error: shape (10000,1) = column required but (10000,) = list given\n\nout_data[:, "suspicious"] = mask', 'filename': None}], 'scriptText': 'from Orange.data import Domain, DiscreteVariable\n\nsus_var = DiscreteVariable("suspicious", values=["False", "True"])\n\nnew_domain = Domain(in_data.domain.attributes + (sus_var,), in_data.domain.class_vars)\n\nout_data = in_data.transform(new_domain) # add col\n\ncol_idx = in_data.domain.index("shooting_percentage_calculated")\nmask = (in_data.X[:, col_idx] &gt; 65)[:, None] # because error: shape (10000,1) = column required but (10000,) = list given\n\nout_data[:, "suspicious"] = mask', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\xa1\x00\x00\x00a\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
